{
  "name": "tsukue",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "deploy:cf": "pnpm --filter web build && wrangler pages deploy apps/web/dist --project-name=tsukue",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "prepare": "husky"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "*.{ts,tsx,astro,mdx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,yaml,yml,md}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "secretlint": "^13.0.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "8",
    "wrangler": "^3.0.0"
  }
}
