{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "astro build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.0",
    "@astrojs/react": "^5.0.6",
    "@fontsource/cabin": "^5.2.8",
    "@fontsource/monaspace-argon": "^5.2.5",
    "@fontsource/newsreader": "^5.2.10",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.0",
    "framer-motion": "^12.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "playwright": "^1.50.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^3.0.0"
  }
}
