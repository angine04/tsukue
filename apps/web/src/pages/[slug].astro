---
import Layout from "../layouts/Layout.astro";
import ArticleSheet from "../components/desk/ArticleSheet";

export async function getStaticPaths() {
  return [
    { params: { slug: "placeholder" } },
  ];
}

const { slug } = Astro.params;
---

<Layout title={`Post: ${slug}`} description="Article placeholder">
  <div class="desk min-h-screen">
    <div class="container mx-auto px-4 py-8">
      <ArticleSheet client:load lang="en" />
    </div>
  </div>
</Layout>
