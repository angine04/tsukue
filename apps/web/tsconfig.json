{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@angineblog/config": ["../../packages/config/src/index.ts"],
      "@angineblog/schemas": ["../../packages/schemas/src/index.ts"],
      "@angineblog/types": ["../../packages/types/src/index.ts"],
      "@angineblog/mail": ["../../packages/mail/src/index.ts"]
    }
  },
  "references": [
    { "path": "../../packages/config" },
    { "path": "../../packages/schemas" },
    { "path": "../../packages/types" },
    { "path": "../../packages/mail" }
  ]
}
